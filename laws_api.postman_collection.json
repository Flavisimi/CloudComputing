    {
      "name": "Laws",
      "item": [
        {
          "name": "GET /laws — page 1 (default)",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws",
              "host": ["{{base_url}}"], "path": ["laws"]
            },
            "description": "Prima pagină (5 rezultate), sortare implicită created_at ASC."
          }
        },
        {
          "name": "GET /laws — page 2",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?page=2",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "page", "value": "2", "description": "Număr pagină, începe de la 1" }]
            }
          }
        },
        {
          "name": "GET /laws — sort title DESC",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?sort=title&order=desc",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [
                { "key": "sort",  "value": "title",  "description": "Câmpuri permise: title | created_at | status | promulgation_date" },
                { "key": "order", "value": "desc",   "description": "asc | desc" }
              ]
            }
          }
        },
        {
          "name": "GET /laws — sort promulgation_date ASC",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?sort=promulgation_date&order=asc",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [
                { "key": "sort",  "value": "promulgation_date" },
                { "key": "order", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "GET /laws — filter status=active",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?status=active",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "status", "value": "active", "description": "draft | active | repealed" }]
            }
          }
        },
        {
          "name": "GET /laws — filter status=draft",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?status=draft",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "status", "value": "draft" }]
            }
          }
        },
        {
          "name": "GET /laws — filter status=repealed",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?status=repealed",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "status", "value": "repealed" }]
            }
          }
        },
        {
          "name": "GET /laws — filter title keyword",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?title=digital",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "title", "value": "digital", "description": "ILIKE match parțial, case-insensitive" }]
            }
          }
        },
        {
          "name": "GET /laws — combined: status + sort + page",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?status=active&sort=promulgation_date&order=desc&page=1",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [
                { "key": "status", "value": "active" },
                { "key": "sort",   "value": "promulgation_date" },
                { "key": "order",  "value": "desc" },
                { "key": "page",   "value": "1" }
              ]
            },
            "description": "Legi active, sortate după data promulgării, cele mai recente primele."
          }
        },
        {
          "name": "GET /laws — invalid status (400)",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?status=unknown",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "status", "value": "unknown" }]
            },
            "description": "Returnează 400 pentru valoare invalidă de status."
          }
        },
        {
          "name": "GET /laws — invalid sort field (400)",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws?sort=nonexistent",
              "host": ["{{base_url}}"], "path": ["laws"],
              "query": [{ "key": "sort", "value": "nonexistent" }]
            },
            "description": "Returnează 400 cu lista câmpurilor permise."
          }
        },
        {
          "name": "POST /laws — minimal (doar title)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Law on Digital Identity\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/laws", "host": ["{{base_url}}"], "path": ["laws"] },
            "description": "Singurul câmp obligatoriu este title. Status implicit: draft."
          }
        },
        {
          "name": "POST /laws — complet",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Law on Environmental Protection\",\n  \"description\": \"Reglementează emisiile industriale și managementul deșeurilor.\",\n  \"status\": \"active\",\n  \"metadata\": {\n    \"importance\": \"high\",\n    \"source\": \"official_monitor\",\n    \"reference_number\": \"LP-2024-042\",\n    \"ministry\": \"Ministry of Environment\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/laws", "host": ["{{base_url}}"], "path": ["laws"] }
          }
        },
        {
          "name": "POST /laws — status invalid (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bad Law\",\n  \"status\": \"published\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/laws", "host": ["{{base_url}}"], "path": ["laws"] },
            "description": "422 — status trebuie să fie draft | active | repealed."
          }
        },
        {
          "name": "POST /laws — title lipsă (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Fără titlu\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/laws", "host": ["{{base_url}}"], "path": ["laws"] }
          }
        },
        {
          "name": "POST /laws — JSON invalid (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ title: missing quotes }",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/laws", "host": ["{{base_url}}"], "path": ["laws"] }
          }
        },
        {
          "name": "GET /laws/:id",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws/{{law_id}}",
              "host": ["{{base_url}}"], "path": ["laws", "{{law_id}}"]
            },
            "description": "Returnează legea cu UUID-ul dat. 404 dacă nu există sau e soft-deleted."
          }
        },
        {
          "name": "GET /laws/:id — not found (404)",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{base_url}}/laws/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"], "path": ["laws", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
        {
          "name": "PUT /laws/:id — Full Replacement",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Completely New Law Title\",\n  \"description\": \"Noua descriere care o suprascrie pe cea veche.\",\n  \"status\": \"repealed\",\n  \"metadata\": {\n    \"replaced_entirely\": true\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/laws/{{law_id}}",
              "host": ["{{base_url}}"],
              "path": ["laws", "{{law_id}}"]
            },
            "description": "Înlocuiește complet resursa. Câmpurile omise (ex: metadata) vor fi setate la empty/null. Titlul și statusul sunt obligatorii."
          }
        },
        {
          "name": "PATCH /laws/:id — merge metadata",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"importance\": \"critical\",\n  \"reviewed_by\": \"Ministry of Justice\",\n  \"last_review\": \"2024-11-01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/laws/{{law_id}}",
              "host": ["{{base_url}}"], "path": ["laws", "{{law_id}}"]
            },
            "description": "Merge JSON în coloana metadata (JSONB ||). Cheile existente sunt suprascrise."
          }
        },
        {
          "name": "PATCH /laws/:id — body gol (422)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "url": {
              "raw": "{{base_url}}/laws/{{law_id}}",
              "host": ["{{base_url}}"], "path": ["laws", "{{law_id}}"]
            }
          }
        },
        {
          "name": "DELETE /laws/:id",
          "request": {
            "method": "DELETE", "header": [],
            "url": {
              "raw": "{{base_url}}/laws/{{law_id}}",
              "host": ["{{base_url}}"], "path": ["laws", "{{law_id}}"]
            },
            "description": "Soft-delete: setează deleted_at. Legea dispare din GET /laws. 404 dacă deja ștearsă."
          }
        },
        {
          "name": "DELETE /laws/:id — deja ștearsă (404)",
          "request": {
            "method": "DELETE", "header": [],
            "url": {
              "raw": "{{base_url}}/laws/{{law_id}}",
              "host": ["{{base_url}}"], "path": ["laws", "{{law_id}}"]
            },
            "description": "Rulează a doua oară după DELETE de mai sus — trebuie să returneze 404."
          }
        }
      ]
    },

