            "body": {
              "mode": "raw",
              "raw": "{\n  \"article_number\": 1,\n  \"content\": \"Prezentul articol stabilește principiile generale de protecție a mediului aplicabile tuturor entităților juridice care operează pe teritoriul național.\"\n}",
